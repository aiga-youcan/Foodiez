{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start JSON Server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "server"],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*json-server.*",
          "endsPattern": "^.*Listening.*"
        }
      }
    }
  ]
}
